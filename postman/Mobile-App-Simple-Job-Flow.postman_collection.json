                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"companyId\": \"{{companyId}}\",\n  \"action\": \"sign\",\n  \"protocolData\": {\n    \"signature\": \"data:image/png;base64,...\",\n    \"customerName\": \"Customer Name\"\n  }\n}"
                },
                "url": "{{baseUrl}}/api/mobile/jobs/{{dealId}}/protocol"
              }
            },
            {
              "name": "10–12. Repair complete with AFTER photos",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Authorization", "value": "{{mobileToken}}" },
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"companyId\": \"{{companyId}}\",\n  \"endTime\": \"2026-02-21T12:00:00.000Z\",\n  \"afterPhotos\": [\"data:image/jpeg;base64,...\"],\n  \"afterPhotoUrls\": []\n}"
                },
                "url": "{{baseUrl}}/api/mobile/jobs/{{dealId}}/repair-complete"
              }
            },
            {
              "name": "13. Work summary agree + invoice (IFA/EFA see Simple Job Flow)",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Authorization", "value": "{{mobileToken}}" },
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"companyId\": \"{{companyId}}\",\n  \"agreed\": true\n}"
                },
                "url": "{{baseUrl}}/api/mobile/jobs/{{dealId}}/work-summary"
              }
            },
            {
              "name": "13a. Invoice – iFA (internal, after surcharge approved)",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Authorization", "value": "{{mobileToken}}" },
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"companyId\": \"{{companyId}}\",\n  \"action\": \"create\"\n}"
                },
                "url": "{{baseUrl}}/api/mobile/jobs/{{dealId}}/invoice"
              }
            },
            {
              "name": "13b. Invoice – eFA (external, after surcharge approved)",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Authorization", "value": "{{mobileToken}}" },
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"companyId\": \"{{companyId}}\",\n  \"action\": \"create_efa\",\n  \"invoiceData\": {\n    \"amountWithoutVAT\": 80,\n    \"vatEnum\": \"Prenos DPH 21%\",\n    \"deliveryDate\": \"2026-02-21\",\n    \"variableSymbol\": \"123\",\n    \"file\": \"data:application/pdf;base64,...\"\n  }\n}"
                },
                "url": "{{baseUrl}}/api/mobile/jobs/{{dealId}}/invoice"
              }
            }
