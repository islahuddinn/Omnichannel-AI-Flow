            },
            {
              "name": "3. Start work (with GPS)",
              "request": {
                "method": "POST",
                "header": [
                  { "key": "Authorization", "value": "{{mobileToken}}" },
                  { "key": "Content-Type", "value": "application/json" }
                ],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"companyId\": \"{{companyId}}\",\n  \"gpsLocation\": {\n    \"latitude\": 32.07,\n    \"longitude\": 74.19,\n    \"accuracy\": 10\n  }\n}"
                },
                "url": "{{baseUrl}}/api/mobile/jobs/{{dealId}}/start"
