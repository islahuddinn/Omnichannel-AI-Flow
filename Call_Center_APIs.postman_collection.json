              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"answered\",\n  \"duration\": 180\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/call-status-tabs/{{statusId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "call-status-tabs", "{{statusId}}"]
            },
            "description": "Update a call status record"
          }
        },
        {
          "name": "Delete Call Status Record",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
