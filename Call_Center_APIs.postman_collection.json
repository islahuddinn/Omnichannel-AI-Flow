                {
                  "key": "limit",
                  "value": "10",
                  "description": "Items per page"
                },
                {
                  "key": "caller_number",
                  "value": "",
                  "description": "Filter by caller number",
                  "disabled": true
                },
                {
                  "key": "reciever_number",
                  "value": "",
                  "description": "Filter by receiver number",
                  "disabled": true
                },
                {
                  "key": "group_id",
                  "value": "",
                  "description": "Filter by group ID",
                  "disabled": true
                },
                {
                  "key": "start_date",
                  "value": "",
                  "description": "Filter by start date",
                  "disabled": true
                },
                {
                  "key": "end_date",
                  "value": "",
                  "description": "Filter by end date",
                  "disabled": true
                },
                {
                  "key": "query",
                  "value": "",
                  "description": "Search query",
                  "disabled": true
                },
                {
                  "key": "filter",
                  "value": "",
                  "description": "Filter by direction",
                  "disabled": true
                }
              ]
            },
            "description": "Get call logs for an agent. Access is controlled based on agent's call_access setting: 'only-calls-by-him', 'calls-by-him-and-group', or 'all-calls'."
          }
        },
        {
          "name": "Delete Call Log",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
