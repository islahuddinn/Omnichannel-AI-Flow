        {
          "name": "Upload Audio File",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": []
                },
                {
                  "key": "is_default",
                  "value": "false",
                  "type": "text",
                  "description": "Set as default audio file"
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/audio-files",
              "host": ["{{baseUrl}}"],
              "path": ["api", "audio-files"]
            },
            "description": "Upload an audio file (MP3, WAV, etc.)"
          }
        }
      ]
    },
    {
      "name": "4. Call Status Tabs",
      "item": [
        {
          "name": "Get All Call Status Records",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/call-status-tabs?page=1&limit=10&sortBy=time&sortOrder=DESC",
              "host": ["{{baseUrl}}"],
              "path": ["api", "call-status-tabs"],
              "query": [
                {
                  "key": "page",
                  "value": "1",
                  "description": "Page number"
                },
                {
                  "key": "limit",
                  "value": "10",
                  "description": "Items per page"
                },
                {
                  "key": "sortBy",
                  "value": "time",
                  "description": "Sort field (time, phoneNumber, status, direction, duration, userId)"
                },
                {
                  "key": "sortOrder",
                  "value": "DESC",
                  "description": "Sort order (ASC or DESC)"
                },
                {
                  "key": "status",
                  "value": "",
                  "description": "Filter by status",
                  "disabled": true
                },
                {
                  "key": "direction",
                  "value": "",
                  "description": "Filter by direction",
                  "disabled": true
                },
                {
                  "key": "phoneNumber",
                  "value": "",
                  "description": "Filter by phone number",
                  "disabled": true
                },
                {
                  "key": "search",
                  "value": "",
                  "description": "Search across phoneNumber, status, direction",
                  "disabled": true
                },
                {
                  "key": "userId",
                  "value": "",
                  "description": "Filter by user ID (admins only)",
                  "disabled": true
                }
              ]
            },
            "description": "Get all call status records with pagination, filtering, and search"
          }
        },
        {
          "name": "Create Call Status Record",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
