    {
      "name": "5. Call Logs",
      "item": [
        {
          "name": "Get All Call Logs",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/call-logs?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "call-logs"],
              "query": [
                {
                  "key": "page",
                  "value": "1",
                  "description": "Page number"
                },
                {
                  "key": "limit",
                  "value": "10",
                  "description": "Items per page"
                },
                {
                  "key": "operator_id",
                  "value": "",
                  "description": "Filter by operator ID (comma-separated for multiple)",
                  "disabled": true
                },
                {
                  "key": "caller_number",
                  "value": "",
                  "description": "Filter by caller number (comma-separated for multiple)",
                  "disabled": true
                },
                {
                  "key": "reciever_number",
                  "value": "",
                  "description": "Filter by receiver number (comma-separated for multiple)",
                  "disabled": true
                },
                {
                  "key": "group_id",
                  "value": "",
                  "description": "Filter by group ID (comma-separated for multiple)",
                  "disabled": true
                },
                {
                  "key": "start_date",
                  "value": "",
                  "description": "Filter by start date (ISO format)",
                  "disabled": true
                },
                {
                  "key": "end_date",
                  "value": "",
                  "description": "Filter by end date (ISO format)",
                  "disabled": true
                },
                {
                  "key": "operator_name",
                  "value": "",
                  "description": "Filter by operator name (comma-separated for multiple)",
                  "disabled": true
                },
                {
                  "key": "query",
                  "value": "",
                  "description": "Search across caller number, receiver number, operator name",
                  "disabled": true
                },
                {
                  "key": "filter",
                  "value": "",
                  "description": "Filter by direction (incoming, outgoing, allcalls)",
                  "disabled": true
                }
              ]
            },
            "description": "Get all call logs with filtering, pagination, and search. Returns call logs with statistics."
          }
        },
        {
          "name": "Create or Update Call Log",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"human\",\n  \"callId\": \"call-12345\",\n  \"userId\": \"{{userId}}\",\n  \"transcript\": \"Call transcript text\",\n  \"summary\": \"Call summary\",\n  \"cdrData\": {\n    \"call_id\": \"call-12345\",\n    \"sourcenum\": \"+1234567890\",\n    \"destinationnum\": \"+0987654321\",\n    \"direction\": \"in\",\n    \"disposition\": \"ANSWERED\",\n    \"duration\": 120,\n    \"calldate\": \"2024-01-15T10:30:00Z\",\n    \"operator_id\": \"{{userId}}\",\n    \"group_id\": \"{{groupId}}\",\n    \"mfile\": \"/var/spool/asterisk/recording.mp3\"\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/call-logs",
              "host": ["{{baseUrl}}"],
              "path": ["api", "call-logs"]
            },
            "description": "Create or update a call log. If type is 'human', it will process recording and call voice bot API. If type is 'voicebot', it will update existing call log with transcript and summary."
          }
        },
