              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"answered\",\n  \"phoneNumber\": \"+1234567890\",\n  \"direction\": \"incoming\",\n  \"time\": \"2024-01-15T10:30:00Z\",\n  \"duration\": 120\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/call-status-tabs",
              "host": ["{{baseUrl}}"],
              "path": ["api", "call-status-tabs"]
            },
            "description": "Create a new call status record"
