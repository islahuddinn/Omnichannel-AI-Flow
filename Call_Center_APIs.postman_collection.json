{
  "info": {
    "name": "Call Center APIs",
    "description": "Complete API collection for Call Center features: Phone Numbers, Call Routes, Audio Files, Call Status Tabs, Call Logs, and Call Groups",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "phoneNumberId",
      "value": "",
      "type": "string"
    },
    {
      "key": "statusId",
      "value": "",
      "type": "string"
    },
    {
      "key": "callLogId",
      "value": "",
      "type": "string"
    },
    {
      "key": "groupId",
      "value": "",
      "type": "string"
    },
    {
      "key": "audioFileId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Phone Numbers",
      "item": [
        {
          "name": "Get All Phone Numbers",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/phone-numbers?page=1&limit=10&search=",
              "host": ["{{baseUrl}}"],
              "path": ["api", "phone-numbers"],
              "query": [
                {
                  "key": "page",
                  "value": "1",
                  "description": "Page number"
                },
                {
                  "key": "limit",
                  "value": "10",
                  "description": "Items per page"
                },
                {
                  "key": "search",
                  "value": "",
                  "description": "Search in phone number or internal name",
                  "disabled": true
                }
              ]
            },
            "description": "Get all phone numbers with pagination and search"
          }
        },
        {
          "name": "Create Phone Number",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phoneNumber\": \"+1234567890\",\n  \"internalName\": \"Main Office Line\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/phone-numbers",
              "host": ["{{baseUrl}}"],
              "path": ["api", "phone-numbers"]
            },
            "description": "Create a new phone number"
          }
        },
        {
          "name": "Update Phone Number",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phoneNumber\": \"+1234567890\",\n  \"internalName\": \"Updated Name\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/phone-numbers/{{phoneNumberId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "phone-numbers", "{{phoneNumberId}}"]
            },
            "description": "Update a phone number"
          }
        }
      ]
    },
    {
      "name": "2. Call Routes",
      "item": [
        {
          "name": "Create or Update Call Routing",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phoneNumberId\": \"{{phoneNumberId}}\",\n  \"flowData\": {\n    \"action\": \"route\",\n    \"destination\": \"group\",\n    \"groupId\": \"{{groupId}}\"\n  },\n  \"isLoop\": 0\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/call-routes",
              "host": ["{{baseUrl}}"],
              "path": ["api", "call-routes"]
            },
            "description": "Create or update call routing for a phone number"
          }
        },
        {
          "name": "Get Call Routing by Phone Number",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/call-routes/{{phoneNumberId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "call-routes", "{{phoneNumberId}}"]
            },
            "description": "Get call routing configuration for a phone number"
          }
        }
      ]
    },
    {
      "name": "3. Audio Files",
